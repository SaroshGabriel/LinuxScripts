[
  {
    "output": "HDMI-A-2",
    "layer": "top",
    "position": "top",
    "height": 60,
    "spacing": 4,
    "exclusive": true,
    "modules-left": [
      "hyprland/workspaces",
      "hyprland/window"
    ],
    "modules-center": [
      "clock"
    ],
    "modules-right": [
      "custom/spotify",
      "tray",
      "cpu",
      "memory",
      "temperature",
      "pulseaudio",
      
      "network#speed",
      
      "custom/uptime",
      "custom/power"
    ],
    "hyprland/workspaces": {
      "disable-scroll": false,
      "swap-scroll-direction": false,
      "format": "{icon}",
      "format-icons": {
        "1": "①",
        "2": "②",
        "3": "③",
        "4": "④",
        "5": "⑤",
        "6": "⑥",
        "7": "⑦",
        "8": "⑧",
        "9": "⑨",
        "urgent": "",
        "focused": "",
        "default": ""
      },
      "persistent-workspaces": {
        "1": [
          "HDMI-A-2"
        ],
        "2": [
          "HDMI-A-2"
        ],
        "3": [
          "HDMI-A-2"
        ],
        "4": [
          "HDMI-A-2"
        ],
        "5": [
          "HDMI-A-2"
        ],
        "6": [
          "HDMI-A-2"
        ],
        "7": [
          "HDMI-A-2"
        ],
        "8": [
          "HDMI-A-2"
        ],
        "9": [
          "HDMI-A-2"
        ]
      }
    },
    "hyprland/window": {
      "format": "{}",
      "max-length": 50,
      "separate-outputs": true
    },
    "clock": {
      "timezone": "Asia/Kolkata",
      "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
      "format": " {:%H:%M   %d/%m/%Y}",
      "format-alt": " {:%A, %B %d, %Y}"
    },
    "cpu": {
      "format": " {usage}%",
      "tooltip": true,
      "interval": 2
    },
    "memory": {
      "format": " {}%",
      "tooltip-format": "RAM: {used:0.1f}G / {total:0.1f}G\nSwap: {swapUsed:0.1f}G / {swapTotal:0.1f}G"
    },
    "temperature": {
      "critical-threshold": 80,
      "format-critical": "{icon} {temperatureC}°C",
      "format": "{icon} {temperatureC}°C",
      "format-icons": [
        "",
        "",
        ""
      ]
    },
    "pulseaudio": {
      "format": "{icon} {volume}%",
      "format-bluetooth": "{icon} {volume}%",
      "format-muted": "",
      "format-icons": {
        "headphone": "",
        "hands-free": "",
        "headset": "",
        "phone": "",
        "portable": "",
        "car": "",
        "default": [
          "",
          "",
          ""
        ]
      },
      "scroll-step": 1,
      "max-volume": 100,
      "on-click": "pavucontrol"
    },
    "network": {
      "format-wifi": " {essid}",
      "format-ethernet": " {ipaddr}/{cidr}",
      "format-linked": " {ifname} (No IP)",
      "format-disconnected": "⚠ Disconnected",
      "tooltip-format": "{ifname}: {ipaddr}"
    },
    "tray": {
      "icon-size": 21,
      "spacing": 10
    },
    "custom/spotify": {
      "exec": "~/.config/waybar/scripts/spotify.sh",
      "return-type": "json",
      "format": "{}",
      "on-click": "playerctl play-pause",
      "on-scroll-up": "playerctl next",
      "on-scroll-down": "playerctl previous"
    },
    "custom/power": {
      "format": "⏻",
      "on-click": "~/.config/waybar/scripts/power-menu.sh",
      "tooltip": false
    },
    "network#speed": {
      "interface": "wlp3s0",
      "format": "↑{bandwidthUpBytes:>9} ↓{bandwidthDownBytes:>9}",
      "interval": 2,
      "tooltip": false
    },
    "custom/ip": {
      "exec": "ip route get 1 2>/dev/null | awk '{print $7}' | head -1",
      "interval": 30,
      "format": " {}",
      "tooltip": false
    },
    "custom/uptime": {
      "exec": "uptime -p | sed 's/up //'",
      "interval": 60,
      "format": " {}",
      "tooltip": false
    }
  },
